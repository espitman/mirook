{
  "name": "mirook-reader",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Mirook MRBK reader",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "run": "concurrently -k -s first \"npm:dev\" \"wait-on http://127.0.0.1:5174 && npm run electron\"",
    "build": "tsc -b && vite build"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.120.15",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
